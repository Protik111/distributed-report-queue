# Producer Service
PORT=5000

# Redis Configuration
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379

# Worker Configuration
WORKER_ID=worker-1
WORKER_CONCURRENCY=2
LOG_LEVEL=info
WORKER_PORT=5002
REPORT_BASE_URL=http://localhost:5002/uploads
NODE_ENV=development

# Worker lock duration (ms)
WORKER_LOCK_DURATION=300000

# Dashboard Configuration
DASHBOARD_PORT=5003

# File storage
UPLOADS_PATH=/app/uploads
